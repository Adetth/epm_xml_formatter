/* COMMON FIX: Applies to all passes to reduce repetitive code */
FIX ("BegBalance", &Select_Version, "No Future1", "No Intergroup", "No Segment", "No Book", "No PlanElement", "PE_Percent", {vEntity}, @Relative("Input Currencies", 0), "RBG")

    /* ==================================================== */
    /* PASS 1: ACTUAL                                       */
    /* ==================================================== */
    FIX ("Actual")
        
        /* Islamic Banking */
        FIX (@MATCH("Product", "PR_ISL*"))
            "Islamic Banking" = "No LineItem";
            "No LineItem" = #MISSING; 
        ENDFIX
        
        /* Conventional Banking */
        FIX (@REMOVE(@RELATIVE("RBG Products", 0), @MATCH("Product", "PR_ISL*")))
